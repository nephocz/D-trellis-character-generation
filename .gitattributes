# Force Linux-compatible line endings for source/config files
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Windows-specific scripts, if any
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.mp4 binary
*.glb binary
*.gltf binary
*.fbx binary
*.vrm binary
*.zip binary
*.tar binary
*.gz binary